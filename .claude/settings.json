{
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; npx prettier --write \"$f\" && npx eslint --fix \"$f\"; } 2>/dev/null || true",
            "statusMessage": "Running Prettier & ESLint..."
          }
        ]
      }
    ]
  }
}
